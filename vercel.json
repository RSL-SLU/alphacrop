{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "field-app/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "^/field-app$",
      "dest": "/field-app/dist/index.html"
    },
    {
      "src": "^/field-app/(.*)$",
      "dest": "/field-app/dist/$1"
    },
    {
      "src": "^/$",
      "dest": "/index.html"
    }
  ]
}
