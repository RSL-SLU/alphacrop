{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/images/gdm-logo.png",
      "use": "@vercel/static"
    },
    {
      "src": "public/images/ku-logo.png",
      "use": "@vercel/static"
    },
    {
      "src": "public/images/mosoy-logo.png",
      "use": "@vercel/static"
    },
    {
      "src": "public/images/rsl-logo-transparent.png",
      "use": "@vercel/static"
    },
    {
      "src": "field-app/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "^/images/(.*)$",
      "dest": "/public/images/$1"
    },
    {
      "src": "^/field-app/?$",
      "dest": "/field-app/dist/index.html"
    },
    {
      "src": "^/field-app/(.*)$",
      "dest": "/field-app/dist/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/$",
      "dest": "/index.html"
    }
  ]
}
